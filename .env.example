# Matrix Homeserver
MATRIX_HOMESERVER=https://eddpod.com
MATRIX_BOT_USER_ID=@proxy:eddpod.com
MATRIX_BOT_PASSWORD=your-bot-password-here
MATRIX_BOT_NAME=proxy

# For subsequent runs (after first login)
MATRIX_ACCESS_TOKEN=
MATRIX_DEVICE_ID=

# Webhook server (for agent-shell to connect)
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8765
WEBHOOK_SECRET=your-secret-key-here

# Logging
LOG_LEVEL=INFO
