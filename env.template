# Rename this file to .env and fill in your details
# Matrix Homeserver
MATRIX_HOMESERVER=https://matrix.example.com
MATRIX_BOT_USER_ID=@bot:example.com
MATRIX_BOT_PASSWORD=your-bot-password-here
MATRIX_BOT_NAME=proxy

# For subsequent runs (after first login)
MATRIX_ACCESS_TOKEN=
MATRIX_DEVICE_ID=

# Webhook server (for agent-shell to connect)
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8765
WEBHOOK_SECRET=your-secret-key-here

# Allowed users (comma-separated Matrix user IDs the bot will respond to)
ALLOWED_USERS=@you:example.com

# Logging
LOG_LEVEL=INFO
